{
  "expo": {
    "name": "Dominion Wellness",
    "slug": "dominion-wellness",
    "version": "1.0.0",
    "scheme": "dominionwellness",
    "owner": "dominion-wellness",
    "orientation": "portrait",
    "icon": "./assets/singleLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#012B5D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.dominionwellness",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/singleLogo.png"
      },
      "package": "ai.dominionwellness"
    },
    "web": {
      "favicon": "./assets/singleLogo.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2be3258d-c40d-461f-b91f-7344f0504013"
      }
    }
  }
}
